# Supabase — https://qhfklukesyrsogrijmci.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://qhfklukesyrsogrijmci.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ... (Settings → API → anon public)
SUPABASE_SERVICE_ROLE_KEY=eyJ... (ne jamais exposer côté client)

# Optionnel — scripts/apply-sql.mjs (Settings → Database → Connection string → URI, mode Transaction)
# DATABASE_URL=postgresql://postgres.qhfklukesyrsogrijmci:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_ESSENTIAL=price_xxx
STRIPE_PRICE_PREMIUM=price_xxx

# Brevo
BREVO_API_KEY=xkeysib-...

# Admin CMS — emails autorisés (séparés par des virgules)
# ADMIN_EMAILS=cliente@hydric.fr,admin@example.com

# App — sous-domaine application (ex. https://app.hydric.fr)
NEXT_PUBLIC_APP_URL=http://localhost:3044

# Vitrine — sous-domaine site marketing (ex. https://www.hydric.fr)
# Si identique à APP_URL, pas de séparation (mode dev local).
NEXT_PUBLIC_MARKETING_URL=http://localhost:3044

# Phase dev : accès app ouvert sans abonnement (mettre false en prod)
NEXT_PUBLIC_DEV_OPEN_ACCESS=true

# Phase dev : désactive le magic link (auto si DEV_OPEN_ACCESS=true)
NEXT_PUBLIC_DISABLE_MAGIC_LINK=true
NEXT_PUBLIC_DEV_AUTH_PASSWORD=hydric-dev

# Balances connectées — Withings (https://developer.withings.com)
# Callback OAuth : {NEXT_PUBLIC_APP_URL}/api/scales/withings/callback
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
# FITBIT_CLIENT_ID=
# FITBIT_CLIENT_SECRET=
# GARMIN_CLIENT_ID=
# GARMIN_CLIENT_SECRET=
# SCALE_OAUTH_STATE_SECRET=change-me-in-prod

# Sync automatique des balances (cron Vercel, 6h UTC)
# CRON_SECRET=generate-a-long-random-string
