{
  "name": "hydric-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3044",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3044",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "supabase db push",
    "db:status": "supabase migration list",
    "db:apply": "node scripts/apply-sql.mjs supabase/migrations/001_schema.sql supabase/migrations/002_auth_trigger.sql supabase/migrations/003_seed_recipes.sql supabase/migrations/004_grants.sql",
    "db:recipes": "node scripts/generate-recipes-migration.mjs && npx supabase db push",
    "db:recipes:v2": "node scripts/generate-recipes-migration.mjs data/hydric_recipes.json 012_seed_recipes_v2.sql && npx supabase db push",
    "setup:supabase": "powershell -ExecutionPolicy Bypass -File scripts/setup-supabase.ps1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.17.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "stripe": "^22.2.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "pg": "^8.16.0",
    "postcss": "^8",
    "supabase": "^2.106.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
